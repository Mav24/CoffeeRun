<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CoffeeRun.App">
    <Application.Resources>
        <ResourceDictionary>
            <Style x:Key="labels" TargetType="Label">
                <Setter Property="TextColor" Value="#351209"/>
                <Setter Property="FontSize" Value="Large"/>
                <Setter Property="FontAttributes" Value="Bold"/>
            </Style>
            <Style x:Key="otherlabels" TargetType="Label" BasedOn="{StaticResource labels}">
                <Setter Property="FontSize" Value="Small"/>
                <Setter Property="TextColor" Value="#311109"/>
                <Setter Property="FontAttributes" Value="Bold"/>
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="#351209"/>
                <Setter Property="TextColor" Value="#E0D7C0"/>
                <Setter Property="CornerRadius" Value="25"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>